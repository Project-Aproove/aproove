# ═══════════════════════════════════════════════════════════════
# APROOVE — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no GitHub
# ═══════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── WhatsApp Business API (Meta Cloud API) ─────────────────────
# Obtenha em: https://developers.facebook.com/apps/
# Tutorial de configuração: /DOCUMENTACAO/setup-whatsapp.md
WHATSAPP_VERIFY_TOKEN=aproove_webhook_token_2026
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxxx
WHATSAPP_BUSINESS_ACCOUNT_ID=xxxxxxxxxxxxxxxxx

# ── Claude AI (avaliação inteligente de ideias) ────────────────
# Obtenha em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub (deploy automático) ────────────────────────────────
# Configurado via GitHub Actions (não precisa preencher aqui)
GITHUB_TOKEN=

# ── Futuros: Supabase (banco de dados em produção) ────────────
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxx
